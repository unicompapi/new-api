# Auto-delete uploaded reference files after N days (default 7).
# Upload sets object metadata/tags; enable matching bucket lifecycle on MinIO:
#   mc ilm rule add ALIAS/BUCKET --prefix "seedance/" --expire-days 7
VITE_MINIO_OBJECT_EXPIRE_DAYS=7
